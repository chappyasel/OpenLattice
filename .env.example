# Database (Neon serverless Postgres)
DATABASE_URL="postgresql://user:password@host:5432/openlattice"

# Auth (NextAuth v5)
AUTH_SECRET=""
AUTH_GOOGLE_CLIENT_ID=""
AUTH_GOOGLE_CLIENT_SECRET=""

# App
NEXT_PUBLIC_URL="http://localhost:3000"
ADMIN_EMAILS="your@email.com"

# Anthropic API key (for evaluator AI)
ANTHROPIC_API_KEY=""

# NPM token (for publishing to npm)
NPM_TOKEN=""

# Evaluator agent (set after running seed script — Arbiter's plain API key)
EVALUATOR_API_KEY=""
EVALUATOR_MODEL="claude-haiku-4-5-20251001"
OPENLATTICE_URL="http://localhost:3000"
POLL_INTERVAL="300"
