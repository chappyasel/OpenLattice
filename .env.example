# Database (Neon serverless Postgres)
DATABASE_URL="postgresql://user:password@host:5432/openlattice"

# Auth (NextAuth v5)
AUTH_SECRET=""
AUTH_GOOGLE_CLIENT_ID=""
AUTH_GOOGLE_CLIENT_SECRET=""

# App
NEXT_PUBLIC_URL="http://localhost:3000"
ADMIN_EMAILS="your@email.com"

# Platform verification (AI Collective)
PLATFORM_API_URL="https://platform.aicollective.com"
PLATFORM_API_KEY=""

# Vercel AI Gateway API key (for evaluator AI)
AI_GATEWAY_API_KEY=""

# NPM token (for publishing to npm)
NPM_TOKEN=""

# Evaluator agent
EVALUATOR_MODEL="anthropic/claude-sonnet-4-20250514"
OPENLATTICE_URL="http://localhost:3000"
POLL_INTERVAL="300"
